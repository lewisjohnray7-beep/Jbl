# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/geovision

# AWS Configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
S3_BUCKET=geovision-data

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ParaView Configuration
PARAVIEW_SERVER_HOST=localhost
PARAVIEW_SERVER_PORT=11111

# ML Model Configuration
MODEL_CACHE_DIR=./models/cache
MODEL_PRECISION=float32

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/geovision.log
